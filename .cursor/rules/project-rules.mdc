## 🌍 i18n ÇOK DİL DESTEĞİ

### lib/i18n.ts
```typescript
import i18n from 'i18next'
import { initReactI18next } from 'react-i18next'
import LanguageDetector from 'i18next-browser-languagedetector'
import Backend from 'i18next-http-backend'

export const SUPPORTED_LANGUAGES = {
  en: { name: 'English', nativeName: 'English', rtl: false },
  tr: { name: 'Turkish', nativeName: 'Türkçe', rtl: false },
} as const

// Telegram language detector - Telegram'dan dil kodunu al
const telegramLanguageDetector = {
  name: 'telegramWebApp',
  lookup() {
    try {
      const langCode = (window as any).Telegram?.WebApp?.initDataUnsafe?.user?.language_code
      if (langCode) {
        const supportedLangCode = langCode.split('-')[0]
        if (SUPPORTED_LANGUAGES[supportedLangCode as keyof typeof SUPPORTED_LANGUAGES]) {
          return supportedLangCode
        }
      }
    } catch (error) {
      console.error('Telegram language detection failed:', error)
    }
    return undefined
  }
}

const languageDetector = new LanguageDetector()
languageDetector.addDetector(telegramLanguageDetector)

i18n
  .use(Backend)
  .use(languageDetector)
  .use(initReactI18next)
  .init({
    detection: {
      order: ['telegramWebApp', 'localStorage', 'navigator'],
      caches: ['localStorage'],
    },
    backend: {
      loadPath: '/locales/{{lng}}/{{ns}}.json',
    },
    fallbackLng: 'en',
    ns: ['common', 'auth', 'navigation', 'errors'],
    defaultNS: 'common',
    interpolation: { escapeValue: false },
    react: { useSuspense: false }
  })

export default i18n
```

